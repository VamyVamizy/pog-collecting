        </div>
        <div style="right: 0; top: 0;" class="rightstuff">
            <button id="useWish"></button>
            <img src="../static/icons/buttons_main/lines.png" width="40" height="40" id="burger_btn" class="imgbtn">
        </div>
    </div>
    <%- include("collectionEJS/banner_rightstuff.ejs") %>
    <div id="centerlayout" style="text-align: center;">
        <div id="invcont">
            <div id="searchCont">
                <div class="search-left">
                    <label class="search-widget" for="searchbox">
                        <button type="button" class="sw-icon" aria-label="Search">🔎</button>
                        <div class="sw-body">
                            <input id="searchbox" name="search" type="text" placeholder="Search Pogs..." autocomplete="off">
                        </div>
                        <img id="searchbtn" src="../static/icons/buttons_main/search.png" width="20" height="20" title="Search Pogs" style="display:none;">

                        <div id="filtCont">
                            <button id="filter" title="Filter / Sort">
                                <img src="../static/icons/playerbase/filter.png" width="20" height="20" alt="filter">
                            </button>
                            <div id="filterBox" style="display:none;">
                                <label class="boxcon" for="nameAZ">
                                    <input type="radio" name="filterSort" value="nameAZ" id="nameAZ">
                                    <label for="nameAZ"><p>Name (a-z)</p></label>
                                </label>
                                <label class="boxcon" for="nameZA">
                                    <input type="radio" name="filterSort" value="nameZA" id="nameZA">
                                    <label for="nameZA"><p>Name (z-a)</p></label>
                                </label>
                                <label class="boxcon" for="rarityHf">
                                    <input type="radio" name="filterSort" value="rarityHf" id="rarityHf">
                                    <label for="rarityHf"><p>Rarity (trash to unique)</p></label>
                                </label>
                                <label class="boxcon" for="rarityLf">
                                    <input type="radio" name="filterSort" value="rarityLf" id="rarityLf">
                                    <label for="rarityLf"><p>Rarity (unique to trash)</p></label>
                                </label>
                                <label class="boxcon" for="svHf">
                                    <input type="radio" name="filterSort" value="svHf" id="svHf">
                                    <label for="svHf"><p>Sell Value (high to low)</p></label>
                                </label>
                                <label class="boxcon" for="svLf">
                                    <input type="radio" name="filterSort" value="svLf" id="svLf">
                                    <label for="svLf"><p>Sell Value (low to high)</p></label>
                                </label>
                            </div>
                        </div>
                    </label>
                </div>

                <div class="search-right">
                    <div id="space">0/10</div>
                    <button id="sellAll">Sell All</button>
                </div>
            </div>

            <div id="inventory">
