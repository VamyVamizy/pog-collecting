<script>
    document.addEventListener('DOMContentLoaded', (event) => {
        const storageKey = "defaultValue";
        const mySel = document.getElementById("selectSort");

        if (mySel) {
            const savedValue = localStorage.getItem(storageKey);
            if (savedValue) mySel.value = savedValue;
            mySel.addEventListener("change", function () {
                localStorage.setItem(storageKey, this.value);
            });
        } else {
            const radios = document.querySelectorAll('input[name="filterSort"]');
            const savedValue = localStorage.getItem(storageKey);
            if (savedValue) {
                const sel = document.querySelector(`input[name="filterSort"][value="${savedValue}"]`);
                if (sel) sel.checked = true;
            } else {
                const def = document.querySelector('input[name="filterSort"][value="nameAZ"]');
                if (def) def.checked = true;
            }
            radios.forEach(r => r.addEventListener('change', function () {
                localStorage.setItem(storageKey, this.value);
            }));

            const filterBtn = document.getElementById('filter');
            const filterBox = document.getElementById('filterBox');
            if (filterBtn && filterBox) {
                filterBtn.addEventListener('click', (e) => {
                    e.preventDefault();
                    filterBox.style.display = (filterBox.style.display === 'none' || filterBox.style.display === '') ? 'flex' : 'none';
                });
                document.addEventListener('click', (e) => {
                    if (!filterBtn.contains(e.target) && !filterBox.contains(e.target)) {
                        filterBox.style.display = 'none';
                    }
                });
            }
        }
    });
</script>

<!-- Socket reload: identify this client and listen for force-reload from server -->
<script src="/socket.io/socket.io.js"></script>
<script>
    (function(){
        try {
            const userdataEl = document.getElementById('userdata');
            let userdata = {};
            try { userdata = JSON.parse(userdataEl && (userdataEl.textContent || userdataEl.innerText) || '{}'); } catch (e) { userdata = {}; }
            const fid = userdata && (userdata.fid || userdata.FID) ? userdata.fid : null;
            const sock = io();
            sock.on('connect', () => {
                if (fid != null) sock.emit('identify', { fid: fid });
            });
            sock.on('force-reload', (payload) => {
                try {
                    console.warn('Received force-reload', payload);
                    // small UX: notify then reload
                    alert('Your account was modified by an administrator. The page will reload to apply changes.');
                } catch (e) {}
                window.location.reload();
            });
        } catch (e) {
            console.warn('Socket reload init failed', e);
        }
    })();
</script>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const icon = document.querySelector('.search-widget .sw-icon');
        const input = document.getElementById('searchbox');
        const hiddenBtn = document.getElementById('searchbtn');
        if (!input) return;

        function triggerSearch() {
            const q = input.value || '';
            if (typeof window.performSearch === 'function') {
                window.performSearch(q);
            } else if (hiddenBtn) {
                hiddenBtn.click();
            } else {
                document.dispatchEvent(new CustomEvent('search-inventory', { detail: { q } }));
            }
        }

        if (icon) {
            icon.addEventListener('click', (e) => {
                e.preventDefault();
                input.focus();
                triggerSearch();
            });
        }

        input.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                e.preventDefault();
                const q = input.value || '';
                if (typeof window.performSearch === 'function') {
                    window.performSearch(q);
                } else if (hiddenBtn) {
                    hiddenBtn.click();
                } else {
                    document.dispatchEvent(new CustomEvent('search-inventory', { detail: { q } }));
                }
            }
        });
    });
</script>

</html>