<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pogglebar – Confirm sign in</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            background-color: #1a1a2e;
            color: #e0e0e0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }
        .container {
            text-align: center;
            padding: 3rem 2rem;
            background: #16213e;
            border-radius: 16px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.4);
            max-width: 420px;
            width: 90%;
        }
        h1 {
            font-size: 2.2rem;
            margin-bottom: 0.5rem;
            color: #fff;
        }
        .subtitle {
            font-size: 1.1rem;
            margin-bottom: 2rem;
            color: #aaa;
        }
        .btn {
            display: inline-block;
            padding: 0.85rem 2.5rem;
            font-size: 1.05rem;
            font-weight: 600;
            color: #fff;
            background: #0f3460;
            border: 2px solid #e94560;
            border-radius: 8px;
            text-decoration: none;
            cursor: pointer;
            transition: background 0.2s, transform 0.1s;
        }
        form { padding: 2%; }
        .btn:hover { background: #e94560; transform: translateY(-2px); }
        .avatar { width:96px; height:96px; border-radius:8px; margin: 12px auto; display:block; }
        .muted { color:#999; margin-top:16px; font-size:0.95rem; }
        .actions { margin-top: 18px; }
        .actions form { display:inline-block; margin-right:12px; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Confirm sign in</h1>
        <% if (tokenData) { %>
            <p class="subtitle">Sign in as <strong><%= tokenData.displayName || 'Unknown user' %></strong></p>
            <% if (tokenData.pfp) { %>
                <img src="<%= tokenData.pfp %>" alt="pfp" class="avatar"/>
            <% } %>
        <% } else { %>
            <p class="subtitle">We received a login response but couldn't read details. Confirm to continue.</p>
        <% } %>

        <div class="actions">
            <form method="post" action="/login/confirm">
                <input type="hidden" name="token" value="<%= tokenRaw %>" />
                <button type="submit" class="btn" id="confirmBTN">Confirm sign in</button>
            </form>
            <form method="post" action="/login/cancel">
                <button type="submit" class="btn">Cancel</button>
            </form>
        </div>

        <p class="muted">If you didn't expect this sign-in, cancel and report it.</p>
    </div>
</body>
</html>
